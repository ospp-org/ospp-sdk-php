{
    "name": "ospp/protocol",
    "description": "PHP SDK for the OSPP (Open Self-Service Point Protocol) — enums, envelope, crypto, state machines",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    },
    "suggest": {
        "opis/json-schema": "Required for payload schema validation (^2.3)"
    },
    "autoload": {
        "psr-4": {
            "Ospp\\Protocol\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ospp\\Protocol\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
